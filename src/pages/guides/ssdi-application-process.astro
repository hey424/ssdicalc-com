import BaseLayout from '../../layouts/BaseLayout.astro';
const title = 'The SSDI Application Process | ssdicalc.com';
const description = 'Step-by-step guide to applying for SSDI benefits and navigating denials and appeals.';
---
<BaseLayout title={title} description={description}>
  <h1>The SSDI Application Process</h1>
  <h2>Step 1: Apply</h2>
  <p>Apply online at ssa.gov, by phone at 1-800-772-1213, or at your local SSA office. Submit medical records, work history, and physician statements. Apply as soon as you become disabled — benefits are not retroactive beyond 12 months before your application date.</p>
  <h2>Step 2: Initial Decision</h2>
  <p>SSA decides in 3–6 months. About 33% of initial applications are approved. If denied, appeal immediately — do not file a new application.</p>
  <h2>Step 3: Reconsideration</h2>
  <p>File within 60 days of denial. A different SSA reviewer examines your case. Approval rates at reconsideration are low (~10–15%).</p>
  <h2>Step 4: ALJ Hearing</h2>
  <p>Request a hearing before an Administrative Law Judge within 60 days. Most claimants hire a disability attorney at this stage. ALJ approval rates are approximately 50%. Hearings can take 12–24 months to schedule.</p>
  <h2>Step 5: Appeals Council and Federal Court</h2>
  <p>If the ALJ denies your claim, you can appeal to SSA's Appeals Council, then to federal district court. These stages are lengthy and approval rates are lower.</p>
  <h2>Disability Attorneys</h2>
  <p>Most disability attorneys work on contingency — no fee unless you win. SSA caps attorney fees at 25% of back pay or $7,200, whichever is less (2025 cap).</p>
</BaseLayout>
